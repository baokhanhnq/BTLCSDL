#include "ultrasonic.h"
#include "delay.h"
#include "median_filter.h"

#define MEDIAN_SIZE      5
#define ECHO_TIMEOUT_US  25000

static volatile uint32_t first_capture = 0;
static volatile uint32_t second_capture = 0;
static volatile uint8_t capture_done = 0;

static uint32_t samples[MEDIAN_SIZE];
static void Trigger_HCSR04(void);
static uint8_t ReadPulseWidth(uint32_t *pulse);
static void TIM2_IC_Init(void);

void ultrasonic_Init(void)
{
    TIM2_IC_Init();
}

static void Trigger_HCSR04(void)
{
    GPIOA->BSRR = (1<<0);

    delay_us(10);

    GPIOA->BSRR = (1<<16);
}

static uint8_t ReadPulseWidth(uint32_t *pulse)
{
    capture_done = 0;

    Trigger_HCSR04();

    TIM5->CNT = 0;

    while(capture_done == 0)
    {
        if(TIM5->CNT > ECHO_TIMEOUT_US)
        {
            return 0;
        }
    }

    if(second_capture >= first_capture)
    {
        *pulse = second_capture - first_capture;
    }
    else
    {
        *pulse =
            (0xFFFFFFFF - first_capture)
            + second_capture + 1;
    }

    return 1;
}

uint32_t ultrasonic_GetDistance_x100(void)
{
    uint8_t count = 0;

    uint32_t pulse;

    while(count < MEDIAN_SIZE)
    {
        if(ReadPulseWidth(&samples[count]))
        {
            count++;
        }

        delay_us(200);
    }

    pulse = MedianFilter5(samples);

    return (pulse * 100) / (58*10);
}

static void TIM2_IC_Init(void)
{
    RCC->AHB1ENR |= (1<<0);
    RCC->APB1ENR |= (1<<0);

    GPIOA->MODER &= ~(3<<0);
    GPIOA->MODER |=  (1<<0);

    GPIOA->MODER &= ~(3<<2);
    GPIOA->MODER |=  (2<<2);

    GPIOA->AFR[0] &= ~(15<<4);
    GPIOA->AFR[0] |=  (1<<4);

    TIM2->PSC = 16 - 1;
    TIM2->ARR = 0xFFFFFFFF;

    TIM2->CCMR1 &= ~(3<<8);
    TIM2->CCMR1 |=  (1<<8);

    TIM2->CCER |= TIM_CCER_CC2E;
    TIM2->CCER &= ~TIM_CCER_CC2P;

    TIM2->DIER |= TIM_DIER_CC2IE;

    TIM2->CR1 |= TIM_CR1_CEN;

    NVIC_EnableIRQ(TIM2_IRQn);
}

void TIM2_IRQHandler(void)
{
    static uint8_t edge = 0;

    if(TIM2->SR & TIM_SR_CC2IF)
    {
        if(edge == 0)
        {
            first_capture = TIM2->CCR2;

            TIM2->CCER |= TIM_CCER_CC2P;

            edge = 1;
        }
        else
        {
            second_capture = TIM2->CCR2;

            TIM2->CCER &= ~TIM_CCER_CC2P;

            edge = 0;

            capture_done = 1;
        }

        TIM2->SR &= ~TIM_SR_CC2IF;
    }
}
